{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vault",
  "version": "0.1.2",
  "identifier": "com.vault.psw-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vault",
        "label": "main",
        "width": 800,
        "height": 640,
        "minWidth": 600,
        "minHeight": 500,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/JiaHuiGod/pwd-vault/releases/latest/download/update-{target}-{arch}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ5MUZCMDY0NjFERUUzREEKUldUYTQ5NWhaTEFmMmJNdkVJTkMxTGNRelordldBczRwaDVEMElqZm1XZW8rSXdZZkpjMVNROUoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
